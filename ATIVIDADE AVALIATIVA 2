      "source": [
        "O boxplot mostra a distribuição das notas. Usando o intervalo interquartil, verificamos se existem outliers."
      ],
      "metadata": {
        "id": "jP2VMVGySWyV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Boxplot da variável 'nota'\n",
        "plt.figure(figsize=(6,4))\n",
        "sns.boxplot(x=df['nota'])\n",
        "plt.title(\"Boxplot das notas\")\n",
        "plt.show()\n",
        "\n",
        "# Cálculo do IQR (Interquartile Range)\n",
        "Q1 = df['nota'].quantile(0.25)  # Primeiro quartil\n",
        "Q3 = df['nota'].quantile(0.75)  # Terceiro quartil\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "# Limites para detectar outliers\n",
        "limite_inferior = Q1 - 1.5 * IQR\n",
        "limite_superior = Q3 + 1.5 * IQR\n",
        "\n",
        "# Identificação dos outliers\n",
        "outliers = df[(df['nota'] < limite_inferior) | (df['nota'] > limite_superior)]\n",
        "\n",
        "print(\"Q1:\", Q1)\n",
        "print(\"Q3:\", Q3)\n",
        "print(\"IQR:\", IQR)\n",
        "print(\"Limite inferior:\", limite_inferior)\n",
        "print(\"Limite superior:\", limite_superior)\n",
        "print(\"Outliers encontrados:\")\n",
        "print(outliers)\n"
